# --- Metadata database (Postgres / Aurora) ---
# Local dev: a plain Postgres works. Production: the Scion metadata Aurora cluster.
METADATA_DATABASE_URL="postgres://user:password@localhost:5432/scion"

# --- Provisioner selection ---
# "mock" runs the full app without AWS (simulated clones). "aws" uses real Aurora.
PROVISIONER="mock"

# --- AWS (only required when PROVISIONER=aws) ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Golden Aurora cluster (the source the clones branch from)
GOLDEN_CLUSTER_ID=""
GOLDEN_HOST=""
GOLDEN_DB_NAME="shop"
GOLDEN_MASTER_USER=""
GOLDEN_MASTER_PASSWORD=""
DB_SUBNET_GROUP_NAME=""
DB_SECURITY_GROUP_ID=""

# --- Integrations (optional in mock mode) ---
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""
VERCEL_PROJECT_ID=""
# Repo Scion manages (owner/repo). Can also be picked in Settings > Connections.
GITHUB_REPO=""
GITHUB_TOKEN=""
GITHUB_WEBHOOK_SECRET=""

# --- Demo guardrails ---
DEMO_MAX_BRANCHES="6"
DEMO_TTL_MINUTES="120"
LINEAGE_LIMIT="15"
